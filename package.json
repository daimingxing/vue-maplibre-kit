{
  "name": "vue-maplibre-kit",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./geometry": {
      "types": "./dist/geometry.d.ts",
      "import": "./dist/geometry.js"
    },
    "./plugins/map-feature-snap": {
      "types": "./dist/plugins/map-feature-snap.d.ts",
      "import": "./dist/plugins/map-feature-snap.js"
    },
    "./plugins/line-draft-preview": {
      "types": "./dist/plugins/line-draft-preview.d.ts",
      "import": "./dist/plugins/line-draft-preview.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@watergis/maplibre-gl-terradraw": "^1.13.0",
    "maplibre-gl": "^5.22.0",
    "mitt": "^3.0.1",
    "vue": "^3.5.32",
    "geojson": "^0.5.0",
    "vue-maplibre-gl": "^5.6.1",
    "element-plus": "^2.2.5",
    "@element-plus/icons-vue": "^2.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6",
    "@types/geojson": "^7946.0.16",
    "sass": "^1.26.5",
    "sass-loader": "^8.0.2"
  }
}
